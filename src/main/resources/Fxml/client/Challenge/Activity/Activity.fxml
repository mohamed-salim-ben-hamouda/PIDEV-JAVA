<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="30" style="-fx-padding: 30;" stylesheets="@../../../../styles/challenge.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.Controllers.client.Challenge.Activity.ActivityController">
    <children>

        <VBox fx:id="challengeListContainer" spacing="25.0" pickOnBounds="false" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="20.0" left="10.0" right="18.0" top="6.0"/>
            </padding>
        </VBox>

        <Label styleClass="page-title" text="🚀 Votre Avancement" style="-fx-font-size: 24px;" />

        <VBox fx:id="DescriptionContainer" spacing="15" styleClass="main-card" style="-fx-padding: 25;">
            <children>
                <Label styleClass="challenge-title" text="📝 Description de l'activité" style="-fx-font-size: 18px;" />
                <TextArea fx:id="activity_desc" styleClass="modern-input" prefHeight="80.0" promptText="Décrivez votre activité..." wrapText="true" />
                <Button onAction="#OnMemberActivity" styleClass="primary-btn" text="Enregistrer Description" prefWidth="200" />
            </children>
        </VBox>

        <VBox spacing="15" styleClass="main-card" style="-fx-padding: 25;">
            <children>
                <Label styleClass="challenge-title" text="⚠️ Problème rencontré" style="-fx-font-size: 18px;" />
                <TextArea fx:id="Problem_grp" styleClass="modern-input" prefHeight="80.0" promptText="Décrivez le problème rencontré..." wrapText="true" />
                <Button onAction="#OnProblem" styleClass="primary-btn" text="Enregistrer Problème" prefWidth="200" />
            </children>
        </VBox>

        <!-- 4. Proposez une solution -->
        <VBox fx:id="solutionContainer" spacing="15" styleClass="main-card" style="-fx-padding: 25;">
            <children>
                <Label styleClass="challenge-title" text="💡 Proposez une solution" style="-fx-font-size: 18px;" />
                <VBox spacing="5">
                    <Label styleClass="input-label" text="Choisir un problème à résoudre" />
                    <ComboBox fx:id="problemCombo" styleClass="modern-input" maxWidth="Infinity" promptText="Sélectionnez un problème" />
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="input-label" text="Votre Solution" />
                    <TextArea fx:id="solution_desc" styleClass="modern-input" prefHeight="80.0" promptText="Expliquez votre approche..." wrapText="true" />
                </VBox>
                <Button onAction="#OnSolution" styleClass="primary-btn" text="Enregistrer Solution" prefWidth="200" />
            </children>
        </VBox>

        <!-- 5. Soumission finale -->
        <VBox fx:id="submissionContainer" spacing="15" styleClass="main-card" style="-fx-padding: 25;">
            <children>
                <Label styleClass="challenge-title" text="📤 Soumission finale" style="-fx-font-size: 18px;" />
                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #f8fafc; -fx-padding: 12; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12;">
                    <children>
                        <Button onAction="#onChooseFile" styleClass="action-btn-outline" text="Choisir un fichier" />
                        <Label fx:id="fileNameLabel" styleClass="meta-text" text="Aucun fichier (PDF, ZIP)" />
                    </children>
                </HBox>
                <Button onAction="#onSubmission" styleClass="primary-btn" text="Soumettre le Travail" prefWidth="200" />
            </children>
        </VBox>

        <VBox spacing="20" styleClass="main-card" style="-fx-padding: 25;">
            <children>
                <Label styleClass="challenge-title" text="📊 Suivi de l'activité" />

                <VBox spacing="10">
                    <Label styleClass="input-label" text="📋 Historique des étapes" />
                    <TableView fx:id="descTable" prefHeight="90.0" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="descTextCol" prefWidth="1100.0" text="Description de l'étape" />
                            <TableColumn fx:id="descActionCol" prefWidth="240" text="Actions" />
                        </columns>
                    </TableView>
                    <VBox fx:id="editMemberOverlayHost" managed="false" spacing="10" visible="false" />
                </VBox>

                <VBox spacing="10">
                    <Label styleClass="input-label" text="⚠️ Problems &amp; Solutions" />
                    <TableView fx:id="problemSolutionTable" prefHeight="180.0" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="problemCol" prefWidth="555" text="Problème" />
                            <TableColumn fx:id="solutionCol" prefWidth="555" text="Solution validée" />
                            <TableColumn fx:id="probActionCol" prefWidth="220.0" text="Actions" />
                        </columns>
                    </TableView>
                    <VBox fx:id="editOverlayHost" managed="false" spacing="10" visible="false" />
                </VBox>
            </children>
        </VBox>

    </children>
</VBox>
