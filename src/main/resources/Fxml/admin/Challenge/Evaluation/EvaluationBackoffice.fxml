<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="900.0" prefWidth="1300.0" spacing="25.0" styleClass="dashboard-page"
      stylesheets="@../../../../styles/dashboard.css" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pidev.Controllers.admin.Challenge.Evaluation.EvaluationBackofficeController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
    </padding>

    <VBox spacing="20.0">
        <children>
            <VBox spacing="10.0" styleClass="hero-panel">
                <children>
                    <Label styleClass="hero-eyebrow" text="ADMINISTRATION"/>
                    <Label styleClass="dashboard-title" text="Evaluation Management"/>
                </children>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="10.0"
                          style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 8 15; -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);">
                        <children>
                            <Label style="-fx-text-fill: #64748b; -fx-font-weight: 800; -fx-font-size: 14;" text="⇅"/>
                            <Label style="-fx-text-fill: #64748b; -fx-font-weight: 600;" text="Sort By:"/>
                            <ComboBox fx:id="sortComboBox" prefWidth="180.0" promptText="Select criteria..."
                                      style="-fx-background-color: transparent; -fx-font-size: 13;"/>
                        </children>
                    </HBox>
                </children>
                <VBox.margin>
                    <Insets left="5.0"/>
                </VBox.margin>
            </HBox>
        </children>
    </VBox>

    <ScrollPane fitToHeight="true" hbarPolicy="ALWAYS" styleClass="dashboard-scroll" VBox.vgrow="ALWAYS">
        <content>
            <VBox minWidth="1400.0">
                <children>
                    <GridPane hgap="20" style="-fx-background-color: #102b55; -fx-background-radius: 20 20 0 0;">
                        <padding>
                            <Insets bottom="18.0" left="45.0" right="45.0" top="18.0"/>
                        </padding>
                        <columnConstraints>
                            <ColumnConstraints minWidth="150" prefWidth="180"/>
                            <ColumnConstraints minWidth="200" prefWidth="280"/>
                            <ColumnConstraints minWidth="120" prefWidth="150"/>
                            <ColumnConstraints minWidth="100" prefWidth="110"/>
                            <ColumnConstraints minWidth="110" prefWidth="250"/>
                        </columnConstraints>
                        <children>
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;"
                                   text="GROUP SCORE" GridPane.columnIndex="0"/>
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;"
                                   text="FEEDBACK" GridPane.columnIndex="1"/>
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="STATUS"
                                   GridPane.columnIndex="2"/>
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;"
                                   text="ACTIVITY_ID" GridPane.columnIndex="3"/>
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="ACTIONS"
                                   GridPane.columnIndex="5"/>
                        </children>
                    </GridPane>

                    <VBox fx:id="EvaluationCardsContainer" spacing="15"
                          style="-fx-background-color: #f8fbff; -fx-background-radius: 0 0 20 20; -fx-padding: 20;"/>
                </children>
            </VBox>
        </content>
    </ScrollPane>
</VBox>