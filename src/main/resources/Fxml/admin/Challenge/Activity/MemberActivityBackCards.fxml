<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox alignment="CENTER_LEFT" minHeight="-Infinity" styleClass="hero-side-card" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pidev.Controllers.admin.Challenge.Activity.MemberActivityBackCardsController">
    <padding>
        <Insets bottom="20" left="25" right="25" top="20"/>
    </padding>
    <children>
        <GridPane hgap="20" vgap="10" HBox.hgrow="ALWAYS">
            <padding>
                <Insets left="20" right="20"/>
            </padding>
            <columnConstraints>
                <ColumnConstraints minWidth="50" prefWidth="60"/>
                <ColumnConstraints minWidth="220" prefWidth="320"/>
                <ColumnConstraints minWidth="90" prefWidth="110"/>
                <ColumnConstraints minWidth="110" prefWidth="140"/>
                <ColumnConstraints minWidth="110" prefWidth="140"/>
                <ColumnConstraints minWidth="110" prefWidth="120"/>
            </columnConstraints>
            <children>
                <Label fx:id="idMemberActivity" styleClass="hero-side-text" text="#ID" GridPane.columnIndex="0"/>
                <Label fx:id="activityDescription" styleClass="hero-side-text" text="description" wrapText="true" GridPane.columnIndex="1"/>
                <Label fx:id="indivScore" styleClass="hero-side-text" text="0.0" GridPane.columnIndex="2"/>
                <Label fx:id="idActivityRef" styleClass="hero-side-text" text="#1" GridPane.columnIndex="3"/>
                <Label fx:id="idUserRef" styleClass="hero-side-text" text="#1" GridPane.columnIndex="4"/>

                <HBox alignment="CENTER_RIGHT" spacing="10" GridPane.columnIndex="5">
                    <Button styleClass="action-btn, action-btn-primary" onAction="#OnDelete" text="Delete"/>
                </HBox>
            </children>
        </GridPane>
    </children>
</HBox>

