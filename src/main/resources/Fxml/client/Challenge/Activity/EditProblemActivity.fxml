<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" styleClass="edit-container"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pidev.Controllers.client.Challenge.Activity.EditProblemSolutionController">
    <children>
        <Label styleClass="input-label" text="Problème" />
        <TextArea fx:id="problemTextArea" styleClass="modern-input" prefHeight="90.0" wrapText="true"
                  promptText="Problème..." />
        <Label styleClass="input-label" text="Solution" />
        <TextArea fx:id="solutionTextArea" styleClass="modern-input" prefHeight="90.0" wrapText="true"
                  promptText="Solution..." />
        <Button fx:id="saveButton" onAction="#onSave" styleClass="btn-edit" text="Save" maxWidth="Infinity" />
    </children>
</VBox>
