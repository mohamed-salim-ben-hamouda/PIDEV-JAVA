<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="720.0" prefWidth="1200.0"
           fx:controller="com.pidev.Controllers.client.Challenge.GrpsPredictionController"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox alignment="TOP_CENTER" maxWidth="1080.0" prefWidth="1080.0" spacing="24.0">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>

            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="Group Prediction Overview"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <StackPane prefHeight="38.0"
                                   style="-fx-background-color: rgba(255,255,255,0.96); -fx-background-radius: 999; -fx-padding: 0 18 0 18; -fx-border-color: #dbe7ff; -fx-border-radius: 999;">
                            <children>
                                <Label fx:id="ChallengeName" text="Challenge - Validation Java"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3559e0;" />
                            </children>
                        </StackPane>
                        <Label fx:id="pageStatusLabel" text="Click Predict All Groups to load scores."
                               style="-fx-font-size: 13px; -fx-text-fill: #64748b;" />
                    </children>
                </VBox>

                <Button fx:id="predictAllBtn" mnemonicParsing="false"
                        onAction="#onPredictAll"
                        prefHeight="40.0"
                        style="-fx-background-color: #3559e0; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold;"
                        text="Predict All Groups" />

                <FlowPane alignment="CENTER" hgap="16.0" prefWrapLength="980.0" vgap="16.0">
                    <children>
                        <VBox prefWidth="220.0" spacing="6.0"
                              style="-fx-background-color: rgba(255,255,255,0.94); -fx-background-radius: 18; -fx-padding: 18; -fx-effect: dropshadow(three-pass-box, rgba(15,23,42,0.08), 12, 0, 0, 4);">
                            <children>
                                <Label text="Best Candidate"
                                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                                <Label fx:id="bestCandidateName" text="Not computed yet"
                                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                                <Label fx:id="bestCandidateScore" text="Run Predict All Groups"
                                       style="-fx-font-size: 13px; -fx-text-fill: #16a34a;" />
                            </children>
                        </VBox>



                        <VBox prefWidth="220.0" spacing="6.0"
                              style="-fx-background-color: rgba(255,255,255,0.94); -fx-background-radius: 18; -fx-padding: 18; -fx-effect: dropshadow(three-pass-box, rgba(15,23,42,0.08), 12, 0, 0, 4);">
                            <children>
                                <Label text="Average Confidence"
                                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                                <Label fx:id="averageConfidenceValue" text="--"
                                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                                <Label fx:id="averageConfidenceCaption" text="Waiting for prediction results"
                                       style="-fx-font-size: 13px; -fx-text-fill: #475569;" />
                            </children>
                        </VBox>
                    </children>
                </FlowPane>

                <FlowPane fx:id="groupCards" alignment="CENTER" hgap="18.0" prefWrapLength="1020.0" vgap="18.0" />
            </children>
        </VBox>
    </children>
</StackPane>
