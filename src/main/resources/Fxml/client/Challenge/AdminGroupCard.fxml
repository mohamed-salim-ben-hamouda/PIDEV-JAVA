<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="180.0" spacing="10.0"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #f0f4f8; -fx-border-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);"
      stylesheets="@../../../styles/challenge.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pidev.Controllers.client.Challenge.AdminGroupCardController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
    </padding>
    <children>
        <Label fx:id="groupNameLabel"
               style="-fx-font-size: 13; -fx-font-weight: 500;"
               text="Group Name"
               textFill="#4a5568"/>
        <Button fx:id="chooseBtn"
                maxWidth="Infinity"
                onAction="#OnChoose"
                styleClass="action-btn-outline"
                text="Choose"/>
        <Button fx:id="predictBtn"
                maxWidth="Infinity"
                onAction="#OnPredict"
                styleClass="action-btn-outline"
                text="Predict"/>
        <Label fx:id="predictionStatusLabel"
               style="-fx-font-size: 12;"
               text="Prediction not loaded yet."
               textFill="#475467"
               wrapText="true"/>
        <Label fx:id="predictionPercentagesLabel"
               style="-fx-font-size: 11;"
               textFill="#667085"
               wrapText="true"/>
    </children>
</VBox>
