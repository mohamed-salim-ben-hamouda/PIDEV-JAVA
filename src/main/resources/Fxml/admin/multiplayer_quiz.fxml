<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.pidev.Controllers.admin.MultiplayerQuizController"
           style="-fx-background-color: #f1f5f9;">

    <!-- ══════════════════ SETUP PANE ══════════════════ -->
    <VBox fx:id="setupPane" alignment="CENTER" spacing="0"
          maxWidth="480" maxHeight="620"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.08),20,0,0,6);">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="⚡ Quiz Multijoueur"
               style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #1e293b;">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </Label>
        <Label text="Jouez en temps réel via socket TCP"
               style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;">
            <VBox.margin><Insets bottom="28"/></VBox.margin>
        </Label>

        <Label text="Votre nom"
               style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #64748b;">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </Label>
        <TextField fx:id="playerNameField" promptText="Ex : Alice"
                   style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 14px;">
            <VBox.margin><Insets bottom="20"/></VBox.margin>
        </TextField>

        <Label text="Mode"
               style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #64748b;">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>
        <HBox spacing="16">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
            <RadioButton fx:id="hostRadio" text="🖥  Hôte (lancer le serveur)"
                         style="-fx-font-size: 13px; -fx-text-fill: #1e293b;"/>
            <RadioButton fx:id="clientRadio" text="👤 Client (rejoindre)"
                         style="-fx-font-size: 13px; -fx-text-fill: #1e293b;"/>
        </HBox>

        <Label text="Adresse du serveur"
               style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #64748b;">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </Label>
        <TextField fx:id="serverHostField" promptText="localhost ou IP"
                   style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 14px;">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </TextField>

        <Button text="🚀  Se connecter" onAction="#onConnect"
                maxWidth="Infinity"
                style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 15px; -fx-background-radius: 10; -fx-padding: 13 0; -fx-cursor: hand;">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Button>

        <Label fx:id="setupStatusLabel"
               style="-fx-text-fill: #ef4444; -fx-font-size: 13px;" wrapText="true"/>
    </VBox>

    <!-- ══════════════════ LOBBY PANE ══════════════════ -->
    <VBox fx:id="lobbyPane" visible="false" managed="false"
          alignment="CENTER" spacing="0"
          maxWidth="480"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.08),20,0,0,6);">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label fx:id="lobbyTitleLabel" text="Salle d'attente"
               style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #1e293b;">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </Label>

        <Label text="Joueurs connectés"
               style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #94a3b8;">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </Label>
        <VBox fx:id="playersListBox" spacing="10">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </VBox>

        <Label fx:id="waitingLabel" text="⏳ En attente d'un 2ème joueur..."
               style="-fx-font-size: 14px; -fx-text-fill: #6366f1; -fx-font-weight: 700;" wrapText="true">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </Label>

        <Button text="← Quitter" onAction="#onDisconnect"
                style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px; -fx-padding: 10 20;"/>
    </VBox>

    <!-- ══════════════════ GAME PANE ══════════════════ -->
    <HBox fx:id="gamePane" visible="false" managed="false" spacing="20">
        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

        <!-- Zone question principale -->
        <VBox HBox.hgrow="ALWAYS" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.06),14,0,0,4);">
            <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="questionIndexLabel" text="Question 1/5"
                       style="-fx-font-size: 13px; -fx-text-fill: #6366f1; -fx-font-weight: 700;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="timerLabel" text="20s"
                       style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #1f2937;"/>
            </HBox>

            <Separator>
                <VBox.margin><Insets top="14" bottom="14"/></VBox.margin>
            </Separator>

            <Label fx:id="questionTextLabel" text="Chargement..."
                   style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #1e293b;" wrapText="true">
                <VBox.margin><Insets bottom="24"/></VBox.margin>
            </Label>

            <VBox fx:id="optionsBox" spacing="12"/>
        </VBox>

        <!-- Sidebar scores -->
        <VBox prefWidth="200" spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.06),14,0,0,4);">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="🏅  Scores"
                   style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #1e293b;"/>
            <Separator/>
            <VBox fx:id="scoresBox" spacing="8"/>
        </VBox>
    </HBox>

    <!-- ══════════════════ RESULT PANE ══════════════════ -->
    <VBox fx:id="resultPane" visible="false" managed="false"
          alignment="CENTER" spacing="0"
          maxWidth="500"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.08),20,0,0,6);">
        <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

        <Label text="🏁  Fin de la partie !"
               style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #1e293b;">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>

        <Label fx:id="winnerLabel" text="🏆 Vainqueur : ?"
               style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #10b981;">
            <VBox.margin><Insets bottom="28"/></VBox.margin>
        </Label>

        <Label text="Classement final"
               style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #94a3b8;">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Label>
        <VBox fx:id="finalScoresBox" spacing="10" alignment="CENTER">
            <VBox.margin><Insets bottom="32"/></VBox.margin>
        </VBox>

        <Button text="← Retour au menu" onAction="#onDisconnect"
                maxWidth="Infinity"
                style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 15px; -fx-background-radius: 10; -fx-padding: 13 0; -fx-cursor: hand;"/>
    </VBox>

</StackPane>
