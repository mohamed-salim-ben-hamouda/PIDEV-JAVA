<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="form-scroll" stylesheets="@../../styles/management.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pidev.Controllers.admin.SponsorHackathonFormController">
    <content>
        <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="content-page">
            <children>
                <VBox spacing="30.0" styleClass="form-container">
                    <children>
                        <Label fx:id="formTitle" styleClass="form-title" text="Assign Sponsor to Hackathon" />

                        <VBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="form-label" text="Select Hackathon" />
                                        <ComboBox fx:id="hackathonCombo" maxWidth="1.7976931348623157E308" promptText="Choose a hackathon" styleClass="form-control" />
                                        <Label fx:id="hackathonError" styleClass="error-label" visible="false" />
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="form-label" text="Select Sponsor" />
                                        <ComboBox fx:id="sponsorCombo" maxWidth="1.7976931348623157E308" promptText="Choose a sponsor" styleClass="form-control" />
                                        <Label fx:id="sponsorError" styleClass="error-label" visible="false" />
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="form-label" text="Contribution Type" />
                                        <TextField fx:id="typeField" promptText="e.g. Financial, Technical Support, Prizes" styleClass="form-control" />
                                        <Label fx:id="typeError" styleClass="error-label" visible="false" />
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="form-label" text="Contribution Value ($)" />
                                        <TextField fx:id="valueField" promptText="0.00" styleClass="form-control" />
                                        <Label fx:id="valueError" styleClass="error-label" visible="false" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="15.0" styleClass="form-actions">
                            <children>
                                <Button mnemonicParsing="false" onAction="#cancel" styleClass="btn-secondary" text="Cancel" />
                                <Button mnemonicParsing="false" onAction="#save" styleClass="action-btn-primary" text="Confirm Assignment" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
            </padding>
        </VBox>
    </content>
</ScrollPane>
