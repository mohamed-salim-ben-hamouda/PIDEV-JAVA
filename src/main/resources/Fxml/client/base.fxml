<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="rootPane" prefHeight="800.0" prefWidth="1200.0" stylesheets="@../../styles/navbarstyle.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.Controllers.client.BaseController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" style="-fx-background-color: white; -fx-border-color: #eee; -fx-border-width: 0 0 1 0; -fx-padding: 0 40;">
            <children>
                <ImageView fitHeight="40.0" preserveRatio="true">
                    <image><Image url="@../../images/logo.png" /></image>
                </ImageView>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="25.0">
                    <children>
                        <Label styleClass="nav-link" text="Dashboard" onMouseClicked="#loadDashboard"/>
                        <Label styleClass="nav-link" text="Home" onMouseClicked="#loadHome"/>
                        <Label styleClass="nav-link" text="Courses" onMouseClicked="#loadCourses"/>
                        <Label styleClass="nav-link" text="Groups" onMouseClicked="#loadGroups"/>
                        <MenuButton fx:id="challengesMenu" text="Challenge &amp; Evaluation" styleClass="nav-menu-button">
                            <items>
                                <MenuItem onAction="#loadChallenge" text="Challenge" />
                                <MenuItem text="Evaluation" />
                            </items>
                        </MenuButton>
                        <MenuButton fx:id="CvMenu" text="Jobs &amp; CV" styleClass="nav-menu-button">
                            <items>
                                <MenuItem onAction="#loadMyCV" text="Cv" />
                                <MenuItem onAction="#loadJobs" text="Jobs" />
                            </items>
                        </MenuButton>
                        <Label styleClass="nav-link" text="Hackathon" onMouseClicked="#loadHackathon"/>
                    </children>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#loadLogin" prefHeight="40.0" prefWidth="110.0" styleClass="primary-btn" text="Sign in" />
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #F4F7FB;">
            <content>
                <StackPane>
                    <children>
                        <Pane mouseTransparent="true" styleClass="mesh-gradient" />

                        <VBox fx:id="mainScrollContent" spacing="50.0">
                            <children>
                                <StackPane fx:id="contentArea">
                                    <padding>
                                        <Insets top="40.0" bottom="20.0" left="20.0" right="20.0"/>
                                    </padding>
                                </StackPane>

                                <VBox style="-fx-background-color: #1a202c; -fx-padding: 40;">
                                    <children>
                                        <HBox spacing="100.0" alignment="TOP_CENTER">
                                            <children>
                                                <VBox spacing="10.0" prefWidth="300.0">
                                                    <Label text="Skill Bridge" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                                                    <Label text="Plateforme éducative intelligente pour améliorer les compétences des étudiants." wrapText="true" style="-fx-text-fill: #a0aec0;"/>
                                                </VBox>
                                                <VBox spacing="10.0">
                                                    <Label text="LIENS UTILES" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                                                    <Label text="Aide et FAQ" style="-fx-text-fill: #a0aec0;" styleClass="footer-link"/>
                                                    <Label text="À propos" style="-fx-text-fill: #a0aec0;" styleClass="footer-link"/>
                                                    <Label text="Contact" style="-fx-text-fill: #a0aec0;" styleClass="footer-link"/>
                                                </VBox>
                                                <VBox spacing="10.0">
                                                    <Label text="NOUS CONTACTER" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                                                    <Label text="📞 +216 97347595" style="-fx-text-fill: #a0aec0;"/>
                                                    <Label text="✉️ contact@skillbridge.tn" style="-fx-text-fill: #a0aec0;"/>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <Separator prefWidth="200.0" style="-fx-opacity: 0.1; -fx-padding: 20 0;"/>
                                        <Label alignment="CENTER" maxWidth="Infinity" text="© 2026 Skill Bridge. Tous droits réservés." style="-fx-text-fill: #718096;"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
