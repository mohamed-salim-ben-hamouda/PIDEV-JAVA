<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: transparent;" styleClass="challenge-page"
            xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pidev.Controllers.client.Challenge.Activity.SelectOldActiviesController">
    <stylesheets>
        <URL value="@../../../../styles/challenge.css" />
    </stylesheets>

    <content>
        <VBox fx:id="mainContentContainer" alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: transparent;">
            <children>
                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label style="-fx-text-fill: #6366f1; -fx-font-weight: 800;" text="Student Area" />
                        <Label styleClass="page-title" text="My Old Activities" />
                    </children>
                    <VBox.margin><Insets bottom="20.0" top="40.0" /></VBox.margin>
                </VBox>

                <FlowPane fx:id="ActivityCards" alignment="TOP_CENTER" hgap="25.0" vgap="30.0"
                          prefWrapLength="1100.0" style="-fx-background-color: transparent;">
                    <padding><Insets bottom="40.0" left="20.0" right="20.0" /></padding>
                </FlowPane>
            </children>
        </VBox>
    </content>
</ScrollPane>
