<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.TextField?>

<VBox spacing="16.0" styleClass="admin-page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pidev.Controllers.admin.QuestionManagementController">
    <children>
        <Label styleClass="admin-page-title" text="Question Management" />
        <HBox spacing="10.0" styleClass="toolbar-panel">
            <children>
                <TextField fx:id="searchField" promptText="Search question content..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="sortFieldCombo" onAction="#onSortChanged" prefWidth="150.0" promptText="Sort by" />
                <ComboBox fx:id="directionCombo" onAction="#onSortChanged" prefWidth="110.0" promptText="Order" />
                <Button onAction="#onSearch" styleClass="management-btn" text="Search" />
                <Button onAction="#onRefresh" styleClass="management-btn" text="Refresh" />
            </children>
        </HBox>
        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <HBox spacing="15.0" styleClass="management-rail-header">
                    <children>
                        <Label style="-fx-min-width: 80;" styleClass="management-rail-label" text="ID" />
                        <Label style="-fx-min-width: 300;" styleClass="management-rail-label" text="Content" />
                        <Label style="-fx-min-width: 120;" styleClass="management-rail-label" text="Type" />
                        <Label style="-fx-min-width: 100;" styleClass="management-rail-label" text="Points" />
                    </children>
                </HBox>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS" styleClass="management-list">
                    <VBox fx:id="questionContainer" spacing="10.0" style="-fx-padding: 4 2 4 2;" />
                </ScrollPane>
            </children>
        </VBox>
        <HBox spacing="10.0" styleClass="management-button-row">
            <children>
                <Button onAction="#onAdd" styleClass="management-btn" text="Add" />
                <Button onAction="#onEdit" styleClass="management-btn" text="Edit" />
                <Button onAction="#onDelete" styleClass="management-btn" text="Delete" />
                <Button onAction="#onRefresh" styleClass="management-btn" text="Refresh" />
            </children>
        </HBox>
    </children>
    <padding><Insets top="8.0" right="24.0" bottom="24.0" left="24.0" /></padding>
</VBox>
