<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="900.0" styleClass="root-pane" stylesheets="@../../../styles/login-style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.Controllers.client.User.ForgotPasswordController">
    <children>
        <VBox alignment="CENTER" maxWidth="400.0" maxHeight="-Infinity" spacing="20.0" styleClass="main-card" StackPane.alignment="CENTER">
            <padding><Insets bottom="40.0" left="30.0" right="30.0" top="40.0" /></padding>
            <children>
                <HBox alignment="CENTER">
                    <children>
                        <Label text="Forgot Password">
                            <font><Font name="Segoe UI Bold" size="24.0" /></font>
                        </Label>
                        <Label text=" 🔒" textFill="#e7af07">
                            <font><Font name="Segoe UI Bold" size="24.0" /></font>
                        </Label>
                    </children>
                </HBox>
                
                <!-- Step 1: Email -->
                <VBox fx:id="step1Box" spacing="15.0" alignment="CENTER">
                    <children>
                        <Label text="Entrez votre adresse email pour recevoir un code de vérification." textAlignment="CENTER" wrapText="true" textFill="#5d5b5b" />
                        <VBox styleClass="input-container">
                            <children>
                                <Label text="Email" textFill="#5d5b5b" />
                                <TextField fx:id="emailField" prefHeight="40.0" promptText="votre-email@exemple.com" />
                            </children>
                        </VBox>
                        <Button onAction="#handleSendCode" prefHeight="45.0" prefWidth="354.0" styleClass="primary-btn" text="Envoyer le code">
                            <VBox.margin><Insets top="10.0" /></VBox.margin>
                        </Button>
                    </children>
                </VBox>

                <!-- Step 2: Verification Code -->
                <VBox fx:id="step2Box" spacing="15.0" alignment="CENTER" managed="false" visible="false">
                    <children>
                        <Label text="Nous avons envoyé un code à 6 chiffres à votre adresse email." textAlignment="CENTER" wrapText="true" textFill="#5d5b5b" />
                        <VBox styleClass="input-container">
                            <children>
                                <Label text="Code de vérification" textFill="#5d5b5b" />
                                <TextField fx:id="codeField" prefHeight="40.0" promptText="123456" />
                            </children>
                        </VBox>
                        <Button onAction="#handleVerifyCode" prefHeight="45.0" prefWidth="354.0" styleClass="primary-btn" text="Vérifier le code">
                            <VBox.margin><Insets top="10.0" /></VBox.margin>
                        </Button>
                    </children>
                </VBox>

                <!-- Step 3: New Password -->
                <VBox fx:id="step3Box" spacing="15.0" alignment="CENTER" managed="false" visible="false">
                    <children>
                        <Label text="Entrez votre nouveau mot de passe." textAlignment="CENTER" wrapText="true" textFill="#5d5b5b" />
                        <VBox styleClass="input-container">
                            <children>
                                <Label text="Nouveau mot de passe" textFill="#5d5b5b" />
                                <PasswordField fx:id="newPasswordField" prefHeight="40.0" promptText="........" />
                            </children>
                        </VBox>
                        <VBox styleClass="input-container">
                            <children>
                                <Label text="Confirmer le mot de passe" textFill="#5d5b5b" />
                                <PasswordField fx:id="confirmPasswordField" prefHeight="40.0" promptText="........" />
                            </children>
                        </VBox>
                        <Button onAction="#handleUpdatePassword" prefHeight="45.0" prefWidth="354.0" styleClass="primary-btn" text="Mettre à jour le mot de passe">
                            <VBox.margin><Insets top="10.0" /></VBox.margin>
                        </Button>
                    </children>
                </VBox>
                
                <Button onAction="#handleBackToLogin" prefHeight="45.0" prefWidth="354.0" styleClass="toggle-btn" text="Back to Login">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>
            </children>
        </VBox>
    </children>
</StackPane>
