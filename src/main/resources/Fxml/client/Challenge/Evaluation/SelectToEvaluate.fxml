<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" prefHeight="800.0" prefWidth="1050.0" style="-fx-background-color: transparent;" styleClass="challenge-page" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.Controllers.client.Challenge.Evaluation.SelectToEvaluateController">
    <stylesheets>
        <URL value="@../../../../styles/challenge.css" />
    </stylesheets>

    <content>
        <VBox fx:id="mainContentContainer" alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: transparent;">
            <children>
                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label style="-fx-text-fill: #6366f1; -fx-font-weight: 800;" text="Supervisor Area" />
                        <Label styleClass="page-title" text="My Challenges with Submitted Activities" />
                    </children>
                    <VBox.margin><Insets top="40.0" bottom="20.0"/></VBox.margin>
                </VBox>

                <VBox alignment="TOP_CENTER" spacing="18.0" maxWidth="980.0">
                    <padding><Insets bottom="40.0" left="20.0" right="20.0" /></padding>
                    <children>
                        <FlowPane fx:id="challengeCardsPane" alignment="CENTER" hgap="18.0" vgap="18.0" prefWrapLength="940.0" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
