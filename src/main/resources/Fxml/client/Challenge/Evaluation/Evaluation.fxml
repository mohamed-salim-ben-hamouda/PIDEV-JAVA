<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<?import java.net.URL?>
<ScrollPane fitToWidth="true" styleClass="transparent-scroll" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.Controllers.client.Challenge.Evaluation.EvaluationMainController">
    <stylesheets>
        <URL value="@../../../../styles/challenge.css" />
    </stylesheets>
    <VBox spacing="30" styleClass="challenge-page" style="-fx-padding: 40;">
        <VBox alignment="CENTER" spacing="10">
            <Label text="Supervisor Area" style="-fx-text-fill: #6366f1; -fx-font-weight: bold;"/>
            <Label text="Group Activities" styleClass="page-title"/>
            <HBox alignment="CENTER" spacing="5">
                <Label text="Challenge: " styleClass="meta-text"/>
                <Label fx:id="challengeMetaLabel" text="-" style="-fx-font-weight: bold;"/>
                <Label text=" Group: " styleClass="meta-text"/>
                <Label fx:id="groupMetaLabel" text=" - Group: -" style="-fx-font-weight: bold;"/>
            </HBox>
        </VBox>

        <VBox alignment="CENTER" spacing="10" styleClass="main-card" style="-fx-padding: 30;">
            <Label text="🏆" style="-fx-font-size: 24px;"/>
            <Label fx:id="challengeTitleLabel" text="-" styleClass="challenge-title"/>
            <Label fx:id="challengeDescriptionLabel" text="-" />
            <Button fx:id="startEvaluationBtn" text="Start Evaluation"
                    styleClass="action-btn-outline"
                    onAction="#OnStart"
                    />
        </VBox>

        <VBox fx:id="evaluationContent"  spacing="25" styleClass="main-card" style="-fx-padding: 25;">
            <VBox spacing="5">
                <Label  text="Activity" styleClass="section-title"/>
                <HBox spacing="5">
                    <Label text="Submission File:" style="-fx-font-weight: bold;"/>
                    <Button fx:id="fileBtn"
                            maxWidth="340.0"
                            minWidth="0.0"
                            text="View File"
                            textOverrun="ELLIPSIS"
                            styleClass="file-link-btn"
                            onAction="#openPdfSubmission"/>
                </HBox>
            </VBox>
            <VBox spacing="15">
                <Label text="Problems" styleClass="input-label" style="-fx-font-size: 15px;"/>
                <VBox fx:id="problemsContainer" spacing="20">
                </VBox>
            </VBox>

            <VBox spacing="15">
                <Label text="Members" styleClass="input-label"/>
                <VBox fx:id="membersContainer" spacing="10" />
            </VBox>

            <VBox spacing="10" styleClass="main-card" style="-fx-padding: 30;">
                <Label text="Group Evaluation &amp; Feedback"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-padding: 0 0 5 5;"/>
                <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-padding: 25;">
                    <Label text="Assign a collective grade and upload the final report."
                           style="-fx-font-size: 13; -fx-text-fill: #64748b;"/>
                    <VBox spacing="20" style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-padding: 20;">
                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <Label text="Group Score" prefWidth="100" style="-fx-text-fill: #475569; -fx-font-weight: 500;"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <TextField fx:id="groupScoreInput" prefWidth="65" promptText="0.0"
                                           style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-padding: 8;"/>
                                <Label text="/ 20" style="-fx-text-fill: #6366f1; -fx-font-weight: bold;"/>
                            </HBox>
                        </HBox>
                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <Label text="Report File" prefWidth="100" style="-fx-text-fill: #475569; -fx-font-weight: 500;"/>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Button  fx:id="fileInp" text="Choose PDF File" onAction="#onChooseFile"
                                        style="-fx-background-color: white; -fx-border-color: #6366f1; -fx-text-fill: #6366f1; -fx-border-radius: 6; -fx-padding: 7 15; -fx-cursor: hand;"/>
                                <Label fx:id="fileLabel" text="No file selected" style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
                            </HBox>
                        </HBox>
                    </VBox>
                    <HBox alignment="CENTER">
                        <Button fx:id="submit_feedback" onAction="#OnSubmit" text="Submit Final Evaluation"
                                style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 10 25; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>

        </VBox>
    </VBox>
</ScrollPane>
