<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>

<?import java.net.URL?>
<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pidev.Controllers.client.Challenge.Evaluation.StudentEvaluationController">
    <stylesheets>
        <URL value="@../../../../styles/challenge.css"/>
    </stylesheets>
    <content>
        <VBox alignment="TOP_CENTER" spacing="30" styleClass="challenge-page">
            <padding>
                <Insets bottom="40.0" left="30.0" right="30.0" top="40.0"/>
            </padding>
            <children>

                <VBox alignment="CENTER" spacing="5">
                    <Label style="-fx-text-fill: #6366f1; -fx-font-weight: 800; -fx-font-size: 14;"
                           text="Your Activity"/>
                    <Label text="Evaluation" styleClass="page-title" style="-fx-font-size: 32;"/>
                </VBox>

                <VBox spacing="30" maxWidth="1200" fillWidth="true">
                    <children>

                        <VBox alignment="CENTER" spacing="15" styleClass="main-card" style="-fx-padding: 40;">
                            <ImageView fitHeight="80" fitWidth="80" preserveRatio="true">
                                <Image url="@../../../../images/trophy.jpg"/>
                            </ImageView>
                            <Label fx:id="challengeTitle" text="Challenge Name" styleClass="challenge-title"
                                   style="-fx-font-size: 26;"/>
                            <Label fx:id="challengeDescription" text="Challenge description goes here"
                                   styleClass="challenge-description"/>
                        </VBox>

                        <VBox spacing="35" styleClass="main-card" style="-fx-padding: 40;">

                            <VBox spacing="15">
                                <HBox spacing="12" alignment="CENTER">
                                    <Label text="📄" style="-fx-font-size: 24;"/>
                                    <Label text="Your Submitted Activity" styleClass="section-title"
                                           style="-fx-font-size: 22;"/>
                                </HBox>
                                <VBox spacing="12" styleClass="inner-section-container" alignment="CENTER"
                                      style="-fx-padding: 25;">
                                    <Label fx:id="activityId" text="Activity ID: 90" styleClass="meta-text"
                                           style="-fx-font-size: 14;"/>
                                    <Button text="Open Submission" styleClass="primary-btn"
                                            style="-fx-padding: 10 25; -fx-font-size: 14;" onAction="#openPdfSubmession"/>
                                    <Label fx:id="submittedDate" text="Submitted on: 2026-05-05"
                                           styleClass="status-label" style="-fx-font-size: 13;"/>
                                </VBox>
                            </VBox>

                            <Separator/>

                            <VBox spacing="25">
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label text="📝" style="-fx-font-size: 24;"/>
                                    <Label text="Evaluation Problems" styleClass="section-title"
                                           style="-fx-font-size: 22;"/>
                                </HBox>
                                <VBox fx:id="problemsContainer" spacing="20">
                                </VBox>


                            </VBox>

                            <VBox spacing="30" alignment="CENTER"
                                  style="-fx-background-color: #f0f9ff; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #bae6fd; -fx-border-width: 1; -fx-border-radius: 10;">
                                <HBox spacing="25" alignment="CENTER">
                                    <VBox alignment="CENTER" spacing="10" styleClass="main-card" HBox.hgrow="ALWAYS"
                                          style="-fx-background-radius: 18; -fx-padding: 30;">
                                        <Label text="YOUR INDIVIDUAL SCORE" styleClass="meta-text"
                                               style="-fx-font-size: 12;"/>
                                        <Label fx:id="individualScore" text="0.45" styleClass="challenge-title"
                                               style="-fx-font-size: 32;"/>
                                    </VBox>
                                    <VBox alignment="CENTER" spacing="10" styleClass="main-card" HBox.hgrow="ALWAYS"
                                          style="-fx-background-radius: 18; -fx-padding: 30;">
                                        <Label text="SUBMITTED GROUP SCORE" styleClass="meta-text"
                                               style="-fx-font-size: 12;"/>
                                        <Label fx:id="groupScore" text="0.45" styleClass="challenge-title"
                                               style="-fx-font-size: 32;"/>
                                    </VBox>
                                </HBox>

                                <VBox alignment="CENTER" spacing="8">
                                    <Label text="FINAL SCORE" styleClass="input-label" style="-fx-font-size: 14;"/>
                                    <Label fx:id="finalScore" text="17.9" styleClass="page-title"
                                           style="-fx-font-size: 64;"/>
                                    <Label fx:id="result" text="Passed"
                                           style="-fx-background-color: #dcfce7; -fx-text-fill: #166534; -fx-padding: 10 30; -fx-background-radius: 30; -fx-font-weight: 800; -fx-font-size: 14;"/>
                                </VBox>
                                <HBox spacing="20" alignment="CENTER">
                                    <Button text="View Certificate" styleClass="primary-btn"
                                            style="-fx-padding: 12 30;"/>
                                    <Button text="Download Certificate" styleClass="action-btn-outline"
                                            style="-fx-padding: 12 30;"/>
                                </HBox>
                                <VBox alignment="CENTER" spacing="12">
                                    <Label text="Feedback PDF:" styleClass="section-title" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                                    <HBox alignment="CENTER" spacing="10">
                                        <Button fx:id="openFeedbackBtn" text="Open" onAction="#openPdfFeedback"
                                                styleClass="primary-btn"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <Button  text="View Individual Ranking" styleClass="primary-btn" maxWidth="Infinity"
                                    style="-fx-background-color: #4f46e5; -fx-padding: 15; -fx-font-size: 16;"/>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>