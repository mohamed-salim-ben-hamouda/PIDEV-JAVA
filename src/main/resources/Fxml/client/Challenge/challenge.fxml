<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER"
      fillWidth="true"
      minHeight="0.0"
      maxHeight="Infinity"
      maxWidth="Infinity"
      spacing="18.0"
      styleClass="challenge-page"
      stylesheets="@../../../styles/challenge.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pidev.Controllers.client.Challenge.ChallengeController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="8.0"/>
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="challenge-switcher">
            <children>
                <Button fx:id="myChallengesBtn" text="My Challenges" onAction="#onShowMyChallenges"
                        styleClass="switcher-btn"/>
                <Button fx:id="createChallengeBtn" text="Create Challenge" onAction="#onShowCreateChallenge"
                        styleClass="switcher-btn"/>
                <Button fx:id="calendarBtn" text="Calendar" onAction="#onShowCalendar"
                        styleClass="switcher-btn"/>
                <Region HBox.hgrow="ALWAYS"/>
            </children>
        </HBox>

        <VBox fx:id="myChallengesPane" minHeight="0.0" maxWidth="Infinity" spacing="18.0"
              styleClass="challenge-list-column" VBox.vgrow="ALWAYS">
            <children>
                <Label text="My Challenges" styleClass="page-title"/>
                <VBox fx:id="challengeListContainer" maxWidth="Infinity" spacing="25.0" pickOnBounds="false"
                      style="-fx-background-color: transparent;">
                    <padding>
                        <Insets bottom="20.0" left="10.0" right="18.0" top="6.0"/>
                    </padding>
                </VBox>
            </children>
        </VBox>

        <VBox fx:id="calendarPane" minHeight="0.0" maxWidth="Infinity" spacing="18.0"
              visible="false" managed="false" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="18.0"
                      style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fbff); -fx-background-radius: 30; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(15,23,42,0.08), 16, 0, 0, 4);">
                    <children>



                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button text="&#8249;" onAction="#previousWeek"
                                        style="-fx-background-color: white; -fx-text-fill: #3559e0; -fx-border-color: #c7d2fe; -fx-border-radius: 12; -fx-background-radius: 12; -fx-font-weight: bold; -fx-padding: 6 12;"/>
                                <Label fx:id="monthLabel" text="Apr 21 - Apr 27, 2026"
                                       style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                                <Button text="&#8250;" onAction="#nextWeek"
                                        style="-fx-background-color: white; -fx-text-fill: #3559e0; -fx-border-color: #c7d2fe; -fx-border-radius: 12; -fx-background-radius: 12; -fx-font-weight: bold; -fx-padding: 6 12;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Published"
                                       style="-fx-font-size: 12; -fx-text-fill: #3559e0;"/>
                                <Label text="In Progress"
                                       style="-fx-font-size: 12; -fx-text-fill: #f59e0b;"/>
                                <Label text="Submitted"
                                       style="-fx-font-size: 12; -fx-text-fill: #16a34a;"/>
                                <Label text="Deadline"
                                       style="-fx-font-size: 12; -fx-text-fill: #ef4444;"/>
                                <Label text="Evaluated"
                                       style="-fx-font-size: 12; -fx-text-fill: #0e7490;"/>
                            </children>
                        </HBox>

                        <GridPane fx:id="calendarGrid" hgap="12.0" vgap="12.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.2857"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.2857"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.2857"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.2857"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.2857"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.2857"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.2857"/>
                            </columnConstraints>
                            <children>
                                <StackPane GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 14; -fx-padding: 10;"><children><Label text="Mon" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/></children></StackPane>
                                <StackPane GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 14; -fx-padding: 10;"><children><Label text="Tue" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/></children></StackPane>
                                <StackPane GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 14; -fx-padding: 10;"><children><Label text="Wed" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/></children></StackPane>
                                <StackPane GridPane.columnIndex="3" GridPane.rowIndex="0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 14; -fx-padding: 10;"><children><Label text="Thu" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/></children></StackPane>
                                <StackPane GridPane.columnIndex="4" GridPane.rowIndex="0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 14; -fx-padding: 10;"><children><Label text="Fri" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/></children></StackPane>
                                <StackPane GridPane.columnIndex="5" GridPane.rowIndex="0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 14; -fx-padding: 10;"><children><Label text="Sat" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/></children></StackPane>
                                <StackPane GridPane.columnIndex="6" GridPane.rowIndex="0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 14; -fx-padding: 10;"><children><Label text="Sun" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #64748b;"/></children></StackPane>
                            </children>
                        </GridPane>
                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox fx:id="createChallengePane"
              alignment="TOP_CENTER"
              minHeight="0.0"
              maxWidth="Infinity"
              spacing="15.0"
              styleClass="challenge-form-column"
              visible="false"
              managed="false"
              VBox.vgrow="ALWAYS">
            <children>
                <VBox minHeight="0.0" maxWidth="Infinity" spacing="15.0" styleClass="main-card">
                    <children>
                        <Label text="Create New Challenge" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                        <VBox spacing="5.0">
                            <Label text="Github required" styleClass="input-label"/>
                            <ComboBox fx:id="GithubRequiredCombo" maxWidth="Infinity" promptText="Select Option"
                                      styleClass="modern-input">

                            </ComboBox>
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="PDF File (required)" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="modern-input">
                                <children>
                                    <Button text="Choisir un fichier" onAction="#onChooseFile"
                                            styleClass="action-btn-outline"/>
                                    <Label fx:id="fileInput" text="Aucun fichier n'a ete selectionne"
                                           textFill="#94a3b8" style="-fx-font-size: 11;"/>
                                </children>
                            </HBox>
                            <Label fx:id="FileError" text="Please select a PDF file" textFill="RED" visible="false"
                                   managed="false" style="-fx-text-fill: red;"/>
                        </VBox>
                        <VBox spacing="3.0">
                            <HBox alignment="CENTER" spacing="10.0">
                                <children>
                                    <Button fx:id="GenerateBtn" onAction="#onGenerateInputs" text="Generate inputs"
                                            styleClass="action-btn-outline-feedback"/>
                                </children>
                            </HBox>
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Title" styleClass="input-label"/>
                            <TextField fx:id="TitleInput" promptText="Enter title" styleClass="modern-input"/>
                            <Label fx:id="TitleError" text="Title is required" textFill="RED" visible="false"
                                   managed="false" style="-fx-text-fill: red;"/>
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Target skill" styleClass="input-label"/>
                            <TextField fx:id="TargetSkillInput" promptText="Enter the skill" styleClass="modern-input"/>
                            <Label fx:id="TargetSkillError" text="Target Skill is required" textFill="RED"
                                   visible="false" managed="false" style="-fx-text-fill: red;"/>
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Difficulty" styleClass="input-label"/>
                            <ComboBox fx:id="DifficultyCombo" maxWidth="Infinity" promptText="Select Difficulty"
                                      styleClass="modern-input"/>
                            <Label fx:id="DifficultyError" text="The Difficulty is required" textFill="RED"
                                   visible="false" managed="false" style="-fx-text-fill: red;"/>
                        </VBox>

                        <VBox spacing="5.0">
                            <HBox spacing="10.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Min group nbr" styleClass="input-label"/>
                                    <TextField fx:id="MinGroupNbrInput" text="0" styleClass="modern-input"/>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Max group nbr" styleClass="input-label"/>
                                    <TextField fx:id="MaxGroupNbrInput" text="0" styleClass="modern-input"/>
                                </VBox>
                            </HBox>
                            <Label fx:id="GroupError" text="Invalid group numbers (Min must be &lt;= Max)" textFill="RED"
                                   visible="false" managed="false" style="-fx-text-fill: red;"/>
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Dead line" styleClass="input-label"/>
                            <DatePicker fx:id="DeadlineInput" maxWidth="Infinity" styleClass="modern-input"/>
                            <Label fx:id="DeadlineError" text="A valid deadline is required" textFill="RED"
                                   visible="false" managed="false" style="-fx-text-fill: red;"/>
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Description (text)" styleClass="input-label"/>
                            <TextArea fx:id="DescriptionInput" prefHeight="80.0" promptText="Write a short description"
                                      styleClass="modern-input" wrapText="true"/>
                            <Label fx:id="DescriptionError" text="Description is required" textFill="RED"
                                   visible="false" managed="false" style="-fx-text-fill: red;"/>
                        </VBox>

                        <Button maxWidth="Infinity" styleClass="primary-btn" text="Create Challenge"
                                onAction="#onCreateChallenge">
                            <VBox.margin>
                                <Insets top="10.0"/>
                            </VBox.margin>
                        </Button>
                    </children>
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
                    </padding>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
