<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="900.0" prefWidth="1300.0" spacing="25.0" styleClass="dashboard-page" stylesheets="@../../../../styles/dashboard.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.Controllers.admin.Challenge.Activity.ActivityBackofficeController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox spacing="10.0" styleClass="hero-panel">
        <Label styleClass="hero-eyebrow" text="ADMINISTRATION" />
        <Label styleClass="dashboard-title" text="Activity Management" />
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <children>
            <Button fx:id="activityBtn" onAction="#onShowActivities" styleClass="action-btn, action-btn-primary" text="Activity" />
            <Button fx:id="memberActivityBtn" onAction="#onShowMemberActivities" styleClass="action-btn" text="Member Activity" />
            <Button fx:id="problemSolutionBtn" onAction="#onShowProblemSolutions" styleClass="action-btn" text="Problem Solution" />
        </children>
    </HBox>

    <ScrollPane fitToHeight="true" hbarPolicy="ALWAYS" styleClass="dashboard-scroll" VBox.vgrow="ALWAYS">
        <content>
            <VBox minWidth="1400.0">
                <children>
                    <VBox fx:id="activityTable">
                        <children>
                            <GridPane hgap="20" style="-fx-background-color: #102b55; -fx-background-radius: 20 20 0 0;">
                                <padding>
                                    <Insets bottom="18.0" left="45.0" right="45.0" top="18.0" />
                                </padding>
                                <columnConstraints>
                                    <ColumnConstraints minWidth="150" prefWidth="200" />
                                    <ColumnConstraints minWidth="200" prefWidth="250" />
                                    <ColumnConstraints minWidth="120" prefWidth="140" />
                                    <ColumnConstraints minWidth="100" prefWidth="110" />
                                    <ColumnConstraints minWidth="60" prefWidth="70" />
                                    <ColumnConstraints minWidth="110" prefWidth="120" />
                                </columnConstraints>
                                <children>
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="Submission_File" GridPane.columnIndex="0" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="Submission_Date" GridPane.columnIndex="1" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="Status" GridPane.columnIndex="2" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="id_challenge" GridPane.columnIndex="3" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="id_group" GridPane.columnIndex="4" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="ACTIONS" GridPane.columnIndex="5" />
                                </children>
                            </GridPane>
                            <VBox fx:id="ActivityCardsContainer" spacing="15" style="-fx-background-color: #f8fbff; -fx-background-radius: 0 0 20 20; -fx-padding: 20;" />
                        </children>
                    </VBox>

                    <VBox fx:id="memberActivityTable" managed="false" visible="false">
                        <children>
                            <GridPane hgap="20" style="-fx-background-color: #102b55; -fx-background-radius: 20 20 0 0;">
                                <padding>
                                    <Insets bottom="18.0" left="45.0" right="45.0" top="18.0" />
                                </padding>
                                <columnConstraints>

                                    <ColumnConstraints minWidth="220" prefWidth="320" />
                                    <ColumnConstraints minWidth="90" prefWidth="110" />
                                    <ColumnConstraints minWidth="110" prefWidth="140" />
                                    <ColumnConstraints minWidth="110" prefWidth="140" />
                                    <ColumnConstraints minWidth="110" prefWidth="120" />
                                </columnConstraints>
                                <children>
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="activity_description" GridPane.columnIndex="0" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="indiv_score" GridPane.columnIndex="1" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="id_activity_id" GridPane.columnIndex="2" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="user_id_id" GridPane.columnIndex="3" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="ACTIONS" GridPane.columnIndex="4" />
                                </children>
                            </GridPane>
                            <VBox fx:id="MemberActivityCardsContainer" spacing="15" style="-fx-background-color: #f8fbff; -fx-background-radius: 0 0 20 20; -fx-padding: 20;" />
                        </children>
                    </VBox>

                    <VBox fx:id="problemSolutionTable" managed="false" visible="false">
                        <children>
                            <GridPane hgap="20" style="-fx-background-color: #102b55; -fx-background-radius: 20 20 0 0;">
                                <padding>
                                    <Insets bottom="18.0" left="45.0" right="45.0" top="18.0" />
                                </padding>
                                <columnConstraints>
                                    <ColumnConstraints minWidth="240" prefWidth="360" />
                                    <ColumnConstraints minWidth="160" prefWidth="240" />
                                    <ColumnConstraints minWidth="160" prefWidth="240" />
                                    <ColumnConstraints minWidth="110" prefWidth="140" />
                                    <ColumnConstraints minWidth="110" prefWidth="120" />
                                </columnConstraints>
                                <children>
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="problem_description" GridPane.columnIndex="0" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="group_solution" GridPane.columnIndex="1" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="supervisor_solution" GridPane.columnIndex="2" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="activity_id_id" GridPane.columnIndex="3" />
                                    <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="ACTIONS" GridPane.columnIndex="4" />
                                </children>
                            </GridPane>
                            <VBox fx:id="ProblemSolutionCardsContainer" spacing="15" style="-fx-background-color: #f8fbff; -fx-background-radius: 0 0 20 20; -fx-padding: 20;" />
                        </children>
                    </VBox>

                </children>
            </VBox>
        </content>
    </ScrollPane>
</VBox>
