<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" styleClass="edit-container"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pidev.Controllers.client.Challenge.Activity.EditMemberActivityController">
    <children>
        <Label styleClass="input-label" text="Description de l'étape" />
        <TextArea fx:id="descriptionTextArea" styleClass="modern-input" prefHeight="110.0" wrapText="true"
                  promptText="Description..." />
        <Button onAction="#onSave" styleClass="btn-edit" text="Save" maxWidth="Infinity" />
    </children>
</VBox>

