<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="860.0" prefWidth="1500.0" stylesheets="@../../styles/backoffice.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pidev.Controllers.admin.BaseController">

    <left>
        <VBox prefWidth="264.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <StackPane prefHeight="160.0" styleClass="sidebar-logo-box">
                    <children>
                        <ImageView fitHeight="100.0" preserveRatio="true">
                            <image>
                                <Image url="@../../images/logo.png" />
                            </image>
                        </ImageView>
                    </children>
                </StackPane>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="10.0" styleClass="sidebar-menu">
                            <children>
                                <Label styleClass="menu-section" text="Navigation" />
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        onAction="#loadHome" styleClass="menu-item" text="Back to Home">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-arrow-left" styleClass="menu-icon" />
                                    </graphic>
                                </Button>

                                <Label styleClass="menu-section" text="Main" />
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        onAction="#loadDashboard" styleClass="menu-item" text="Dashboard">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-tachometer-alt" styleClass="menu-icon" />
                                    </graphic>
                                </Button>

                                <Label styleClass="menu-section" text="User Management" />
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Users">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-user" styleClass="menu-icon" />
                                    </graphic>
                                </Button>

                                <Label styleClass="menu-section" text="Pedagogical Management" />
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Courses">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-book" styleClass="menu-icon" />
                                    </graphic>
                                </Button>
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Chapters">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-bookmark" styleClass="menu-icon" />
                                    </graphic>
                                </Button>
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Quizzes">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-question-circle" styleClass="menu-icon" />
                                    </graphic>
                                </Button>
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Questions">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-info-circle" styleClass="menu-icon" />
                                    </graphic>
                                </Button>
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Answers">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-check" styleClass="menu-icon" />
                                    </graphic>
                                </Button>

                                <Label styleClass="menu-section" text="Student Results" />
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Quiz Results">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-chart-bar" styleClass="menu-icon" />
                                    </graphic>
                                </Button>

                                <Label styleClass="menu-section" text="Community" />
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Groups">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-users" styleClass="menu-icon" />
                                    </graphic>
                                </Button>
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Posts">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-comments" styleClass="menu-icon" />
                                    </graphic>
                                </Button>

                                <Label styleClass="menu-section" text="Challenges" />
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Challenges">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-trophy" styleClass="menu-icon" />
                                    </graphic>
                                </Button>
                                <Button alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="menu-item" text="Hackathons">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-flag-checkered" styleClass="menu-icon" />
                                    </graphic>
                                </Button>
                            </children>
                            <padding>
                                <Insets bottom="32.0" left="16.0" right="16.0" top="22.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </left>

    <center>
        <VBox styleClass="admin-shell" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" styleClass="topbar">
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Label styleClass="topbar-title" text="Skill Bridge Admin" />
                                <Label styleClass="topbar-subtitle" text="Manage courses, users, groups, challenges and results" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="8.0" styleClass="profile-chip">
                            <children>
                                <FontIcon iconLiteral="fas-user-circle" styleClass="profile-icon" />
                                <Label styleClass="profile-name" text="Admin" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="36.0" right="36.0" top="30.0" />
                    </padding>
                </HBox>

                <StackPane fx:id="contentArea" styleClass="content-host" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </center>
</BorderPane>
