<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="900.0" prefWidth="1300.0" spacing="25.0" styleClass="dashboard-page" stylesheets="@../../../styles/dashboard.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.Controllers.admin.Challenge.ChallengeBackofficeController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox spacing="10.0" styleClass="hero-panel">
        <Label styleClass="hero-eyebrow" text="ADMINISTRATION" />
        <Label styleClass="dashboard-title" text="Challenge Management" />
    </VBox>

    <ScrollPane fitToHeight="true" hbarPolicy="ALWAYS" styleClass="dashboard-scroll" VBox.vgrow="ALWAYS">
        <content>
            <VBox minWidth="1400.0">
                <children>
                    <GridPane hgap="20" style="-fx-background-color: #102b55; -fx-background-radius: 20 20 0 0;">
                        <padding>
                            <Insets bottom="18.0" left="45.0" right="45.0" top="18.0" />
                        </padding>
                        <columnConstraints>
                            <ColumnConstraints minWidth="50" prefWidth="60" />
                            <ColumnConstraints minWidth="150" prefWidth="200" />
                            <ColumnConstraints minWidth="200" prefWidth="250" />
                            <ColumnConstraints minWidth="120" prefWidth="140" />
                            <ColumnConstraints minWidth="100" prefWidth="110" />
                            <ColumnConstraints minWidth="60" prefWidth="70" />
                            <ColumnConstraints minWidth="60" prefWidth="70" />
                            <ColumnConstraints minWidth="110" prefWidth="120" />
                            <ColumnConstraints minWidth="110" prefWidth="120" />
                        </columnConstraints>
                        <children>
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="ID" GridPane.columnIndex="0" />
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="TITLE" GridPane.columnIndex="1" />
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="DESCRIPTION" GridPane.columnIndex="2" />
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="TARGET SKILL" GridPane.columnIndex="3" />
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="LEVEL" GridPane.columnIndex="4" />
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="MIN" GridPane.columnIndex="5" />
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="MAX" GridPane.columnIndex="6" />
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="DEADLINE" GridPane.columnIndex="7" />
                            <Label style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11;" text="ACTIONS" GridPane.columnIndex="8" />
                        </children>
                    </GridPane>

                    <VBox fx:id="challengeCardsContainer" spacing="15" style="-fx-background-color: #f8fbff; -fx-background-radius: 0 0 20 20; -fx-padding: 20;" />
                </children>
            </VBox>
        </content>
    </ScrollPane>
</VBox>