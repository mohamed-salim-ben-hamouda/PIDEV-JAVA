<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.Controllers.client.CVManagementController">
    <children>
        <VBox spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <padding>
                        <Insets left="40.0" right="40.0" top="40.0" />
                    </padding>
                    <children>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Mes CVs" textFill="#1e293b">
                                    <font>
                                        <Font name="System Bold" size="32.0" />
                                    </font>
                                </Label>
                                <Label text="Gérez vos curriculum vitae et vos candidatures" textFill="#64748b">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <Button mnemonicParsing="false" onAction="#handleShowCreateForm" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 12 25; -fx-background-radius: 10; -fx-cursor: hand;" text="+ Créer un nouveau CV">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>

                <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" />
                    </padding>
                    <children>
                        <!-- CV List Section -->
                        <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                            <children>
                                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: white;" VBox.vgrow="ALWAYS">
                                    <content>
                                        <FlowPane fx:id="cvFlowPane" hgap="20.0" vgap="20.0">
                                            <padding>
                                                <Insets bottom="20.0" right="10.0" top="10.0" />
                                            </padding>
                                        </FlowPane>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                        <!-- Form Section (Card style) -->
                        <VBox fx:id="formContainer" prefWidth="400.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-padding: 30; -fx-border-color: #f1f5f9; -fx-border-radius: 15;">
                            <children>
                                <Label fx:id="formTitleLabel" text="Créer un nouveau CV" textFill="#1e293b">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Label>
                                <VBox spacing="15.0">
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Nom du CV" textFill="#64748b">
                                                    <font>
                                                        <Font name="System Bold" size="12.0" />
                                                    </font>
                                                </Label>
                                                <TextField fx:id="nomCvField" promptText="Ex: CV Développeur Java" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #e2e8f0; -fx-border-radius: 5;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Langue" textFill="#64748b">
                                                    <font>
                                                        <Font name="System Bold" size="12.0" />
                                                    </font>
                                                </Label>
                                                <ComboBox fx:id="langueComboBox" maxWidth="1.7976931348623157E308" promptText="Sélectionnez une langue" style="-fx-padding: 5; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 5;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="URL LinkedIn" textFill="#64748b">
                                                    <font>
                                                        <Font name="System Bold" size="12.0" />
                                                    </font>
                                                </Label>
                                                <TextField fx:id="linkedinUrlField" promptText="https://linkedin.com/in/..." style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #e2e8f0; -fx-border-radius: 5;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Résumé / Profil" textFill="#64748b">
                                                    <font>
                                                        <Font name="System Bold" size="12.0" />
                                                    </font>
                                                </Label>
                                                <TextArea fx:id="summaryArea" prefHeight="150.0" promptText="Présentez-vous en quelques lignes..." style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #e2e8f0; -fx-border-radius: 5;" wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="submitButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSubmitCv" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;" text="Enregistrer" HBox.hgrow="ALWAYS">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Button>
                                        <Button mnemonicParsing="false" onAction="#handleClearForm" style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;" text="Annuler">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
