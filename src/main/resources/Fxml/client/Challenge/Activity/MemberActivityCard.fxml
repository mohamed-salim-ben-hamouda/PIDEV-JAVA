<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<HBox fx:id="root" alignment="CENTER_LEFT" spacing="12.0" styleClass="card-row"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pidev.Controllers.client.Challenge.Activity.MemberActivityCardController">
    <children>
        <Label fx:id="descriptionLabel" maxWidth="1.7976931348623157E308" wrapText="true" styleClass="card-text" HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button fx:id="editBtn" styleClass="action-btn-outline" text="Edit" />
                <Button fx:id="deleteBtn" styleClass="action-btn-delete" text="Delete" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="10.0" left="14.0" right="14.0" top="10.0" />
    </padding>
</HBox>
