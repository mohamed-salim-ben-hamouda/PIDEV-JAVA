<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Rectangle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox alignment="TOP_CENTER" spacing="0.0" stylesheets="@../../styles/home.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.Controllers.client.HomeController">
    <children>
        <!-- Hero Section -->
        <HBox alignment="CENTER" spacing="60.0" style="-fx-background-color: white;">
            <padding><Insets bottom="100.0" left="80.0" right="80.0" top="80.0" /></padding>
            <children>
                <VBox spacing="25.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="hero-title" text="Skill Bridge" />
                    <Label maxWidth="500" styleClass="hero-subtitle" text="Plateforme éducative intelligente pour développer vos compétences et booster votre carrière." wrapText="true" />
                </VBox>
                <ImageView fitHeight="350.0" fitWidth="450.0" preserveRatio="true">
                    <Image url="@../../images/home_pic.jpg" />
                </ImageView>
            </children>
        </HBox>

        <!-- Modules Section -->
        <VBox alignment="CENTER" spacing="30.0">
            <padding><Insets bottom="80.0" left="50.0" right="50.0" top="60.0" /></padding>
            <Label styleClass="section-subtitle" text="EXPLOREZ" />
            <Label styleClass="section-title" text="Nos Modules" />
            <FlowPane alignment="CENTER" hgap="25.0" vgap="25.0">
                <VBox styleClass="module-card" onMouseClicked="#openProfile" style="-fx-cursor: hand;"><Label style="-fx-font-size: 35;" text="&#x1f464;" /><Label styleClass="member-name" text="Profile" /></VBox>
                <VBox styleClass="module-card"><Label style="-fx-font-size: 35;" text="&#x1f4da;" /><Label styleClass="member-name" text="Courses" /></VBox>
                <VBox styleClass="module-card"><Label style="-fx-font-size: 35;" text="&#x1f3c6;" /><Label styleClass="member-name" text="Challenges" /></VBox>
                <VBox styleClass="module-card"><Label style="-fx-font-size: 35;" text="&#x1f4c4;" /><Label styleClass="member-name" text="Internship" /></VBox>
            </FlowPane>
            <FlowPane alignment="CENTER" hgap="25.0" vgap="25.0">
                <VBox styleClass="module-card"><Label style="-fx-font-size: 35;" text="&#x1f465;" /><Label styleClass="member-name" text="Groups" /></VBox>
                <VBox styleClass="module-card"><Label style="-fx-font-size: 35;" text="&#x1f3c1;" /><Label styleClass="member-name" text="Hackathon" /></VBox>
            </FlowPane>
        </VBox>

        <!-- About Section -->
        <HBox alignment="CENTER" spacing="60.0" style="-fx-background-color: #f1f5f9;">
            <padding><Insets bottom="100.0" left="80.0" right="80.0" top="100.0" /></padding>
            <StackPane styleClass="about-img-container">
                <ImageView fitHeight="300.0" fitWidth="400.0" preserveRatio="true">
                    <clip><Rectangle arcHeight="40" arcWidth="40" height="300" width="400" /></clip>
                    <Image url="@../../images/softskills.jpg" />
                </ImageView>
            </StackPane>
            <VBox maxWidth="550" spacing="25.0">
                <Label styleClass="section-subtitle" text="NOTRE HISTOIRE" />
                <Label styleClass="section-title" text="Pourquoi Skill Bridge ?" />
                <TextFlow lineSpacing="8.0">
                    <Text styleClass="about-text" text="Skill Bridge est né d'une vision : créer un espace d'épanouissement. Nous connectons les étudiants avec des défis réels pour forger les talents de demain." />
                </TextFlow>
            </VBox>
        </HBox>

        <!-- Team Section -->
        <VBox alignment="CENTER" spacing="40.0" style="-fx-background-color: white;">
            <padding><Insets bottom="20" left="50.0" right="50.0" top="80.0" /></padding>
            <VBox alignment="CENTER" spacing="10">
                <Label styleClass="section-subtitle" text="L'ÉQUIPE" />
                <Label styleClass="section-title" text="Notre Équipe" />
            </VBox>
            <FlowPane alignment="CENTER" hgap="25.0" prefWrapLength="1000" vgap="35.0">
                <VBox alignment="TOP_CENTER" spacing="15.0" styleClass="main-card">
                    <StackPane>
                        <ImageView fitHeight="130.0" fitWidth="130.0"><clip><Rectangle arcHeight="130" arcWidth="130" height="130" width="130" /></clip><Image url="@../../images/members/salim.png" /></ImageView>
                        <HBox alignment="CENTER" spacing="10.0" styleClass="social-wrapper">
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.facebook.com/profile.php?id=61561583608782"><FontIcon iconLiteral="fab-facebook" iconSize="18" styleClass="fb-icon" /></HBox>
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.instagram.com/salim_benhamouda/"><FontIcon iconLiteral="fab-instagram" iconSize="18" styleClass="insta-icon" /></HBox>
                        </HBox>
                    </StackPane>
                    <VBox alignment="CENTER" spacing="5"><Label styleClass="member-name" text="Salim Ben Hamouda" /><Label styleClass="member-role" text="Member" /></VBox>
                </VBox>
                <VBox alignment="TOP_CENTER" spacing="15.0" styleClass="main-card">
                    <StackPane>
                        <ImageView fitHeight="130.0" fitWidth="130.0"><clip><Rectangle arcHeight="130" arcWidth="130" height="130" width="130" /></clip><Image url="@../../images/members/tasnim.png" /></ImageView>
                        <HBox alignment="CENTER" spacing="10.0" styleClass="social-wrapper">
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.facebook.com/tas.nyme.2025"><FontIcon iconLiteral="fab-facebook" iconSize="18" styleClass="fb-icon" /></HBox>
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.instagram.com/tas_nyme_/"><FontIcon iconLiteral="fab-instagram" iconSize="18" styleClass="insta-icon" /></HBox>
                        </HBox>
                    </StackPane>
                    <VBox alignment="CENTER" spacing="5"><Label styleClass="member-name" text="Tasnim Sammoud" /><Label styleClass="member-role" text="Member" /></VBox>
                </VBox>
                <VBox alignment="TOP_CENTER" spacing="15.0" styleClass="main-card">
                    <StackPane>
                        <ImageView fitHeight="130.0" fitWidth="130.0"><clip><Rectangle arcHeight="130" arcWidth="130" height="130" width="130" /></clip><Image url="@../../images/members/nouh.png" /></ImageView>
                        <HBox alignment="CENTER" spacing="10.0" styleClass="social-wrapper">
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.facebook.com/nouhmznd"><FontIcon iconLiteral="fab-facebook" iconSize="18" styleClass="fb-icon" /></HBox>
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.instagram.com/nouhmznd/"><FontIcon iconLiteral="fab-instagram" iconSize="18" styleClass="insta-icon" /></HBox>
                        </HBox>
                    </StackPane>
                    <VBox alignment="CENTER" spacing="5"><Label styleClass="member-name" text="Nouh Mezned" /><Label styleClass="member-role" text="Member" /></VBox>
                </VBox>
                <VBox alignment="TOP_CENTER" spacing="15.0" styleClass="main-card">
                    <StackPane>
                        <ImageView fitHeight="130.0" fitWidth="130.0"><clip><Rectangle arcHeight="130" arcWidth="130" height="130" width="130" /></clip><Image url="@../../images/members/takoua.png" /></ImageView>
                        <HBox alignment="CENTER" spacing="10.0" styleClass="social-wrapper">
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.facebook.com/takouabettaieb27"><FontIcon iconLiteral="fab-facebook" iconSize="18" styleClass="fb-icon" /></HBox>
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.instagram.com/bettaiebtakoua/"><FontIcon iconLiteral="fab-instagram" iconSize="18" styleClass="insta-icon" /></HBox>
                        </HBox>
                    </StackPane>
                    <VBox alignment="CENTER" spacing="5"><Label styleClass="member-name" text="Takoua Bettaieb" /><Label styleClass="member-role" text="Member" /></VBox>
                </VBox>
                <VBox alignment="TOP_CENTER" spacing="15.0" styleClass="main-card">
                    <StackPane>
                        <ImageView fitHeight="130.0" fitWidth="130.0"><clip><Rectangle arcHeight="130" arcWidth="130" height="130" width="130" /></clip><Image url="@../../images/members/iyed.png" /></ImageView>
                        <HBox alignment="CENTER" spacing="10.0" styleClass="social-wrapper">
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.facebook.com/mohamed.iyed.fadhli"><FontIcon iconLiteral="fab-facebook" iconSize="18" styleClass="fb-icon" /></HBox>
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.instagram.com/iyed_fd/"><FontIcon iconLiteral="fab-instagram" iconSize="18" styleClass="insta-icon" /></HBox>
                        </HBox>
                    </StackPane>
                    <VBox alignment="CENTER" spacing="5"><Label styleClass="member-name" text="Mohamed Iyed Fadhli" /><Label styleClass="member-role" text="Member" /></VBox>
                </VBox>
                <VBox alignment="TOP_CENTER" spacing="15.0" styleClass="main-card">
                    <StackPane>
                        <ImageView fitHeight="130.0" fitWidth="130.0"><clip><Rectangle arcHeight="130" arcWidth="130" height="130" width="130" /></clip><Image url="@../../images/members/oumaima.png" /></ImageView>
                        <HBox alignment="CENTER" spacing="10.0" styleClass="social-wrapper">
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.facebook.com/omaima.barhoumi.58"><FontIcon iconLiteral="fab-facebook" iconSize="18" styleClass="fb-icon" /></HBox>
                            <HBox onMouseClicked="#openSocialLink" styleClass="social-circle" userData="https://www.instagram.com/barhoumiomaima/"><FontIcon iconLiteral="fab-instagram" iconSize="18" styleClass="insta-icon" /></HBox>
                        </HBox>
                    </StackPane>
                    <VBox alignment="CENTER" spacing="5"><Label styleClass="member-name" text="Oumaima Barhoumi" /><Label styleClass="member-role" text="Member" /></VBox>
                </VBox>
            </FlowPane>
        </VBox>
    </children>
</VBox>
