<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox alignment="TOP_CENTER" fillHeight="true" spacing="28.0" styleClass="challenge-page" stylesheets="@../../../styles/challenge.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.Controllers.client.Challenge.ChallengeController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="8.0"/>
    </padding>

    <children>
        <VBox maxHeight="Infinity" minHeight="0.0" spacing="18.0" styleClass="challenge-list-column" HBox.hgrow="ALWAYS">
            <children>
                <Label text="My Challenges" styleClass="page-title"/>

                <ScrollPane fitToWidth="true" maxHeight="Infinity" minHeight="0.0" prefHeight="0.0" styleClass="transparent-scroll" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="challengeListContainer" spacing="25.0" pickOnBounds="false" style="-fx-background-color: transparent;">
                            <padding>
                                <Insets bottom="20.0" left="10.0" right="18.0" top="6.0"/>
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>

        <VBox maxHeight="Infinity" minHeight="0.0" prefWidth="380.0" spacing="15.0" styleClass="challenge-form-column">
            <children>
                <VBox maxHeight="Infinity" minHeight="0.0" spacing="15.0" styleClass="main-card" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="Create New Challenge" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                        <VBox spacing="5.0">
                            <Label text="Title" styleClass="input-label"/>
                            <TextField fx:id="TitleInput" promptText="Enter title" styleClass="modern-input"/>
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Target skill" styleClass="input-label"/>
                            <TextField fx:id="TargetSkillInput" promptText="Enter the skill" styleClass="modern-input"/>
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Difficulty" styleClass="input-label"/>
                            <ComboBox fx:id="DifficultyCombo" maxWidth="Infinity" promptText="Select Difficulty" styleClass="modern-input"/>
                        </VBox>
                        <HBox spacing="10.0">
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label text="Min group nbr" styleClass="input-label"/>
                                <TextField fx:id="MinGroupNbrInput" text="0" styleClass="modern-input"/>
                            </VBox>
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label text="Max group nbr" styleClass="input-label"/>
                                <TextField fx:id="MaxGroupNbrInput" text="0" styleClass="modern-input"/>
                            </VBox>
                        </HBox>
                        <VBox spacing="5.0">
                            <Label text="Dead line" styleClass="input-label"/>
                            <DatePicker fx:id="DeadlineInput" maxWidth="Infinity" styleClass="modern-input"/>
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Description (text)" styleClass="input-label"/>
                            <TextArea fx:id="DescriptionInput" prefHeight="80.0" promptText="Write a short description" styleClass="modern-input" wrapText="true"/>
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="PDF File (required)" styleClass="input-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="modern-input">
                                <children>
                                    <Button text="Choisir un fichier" onAction="#onChooseFile" style="-fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 4;"/>
                                    <Label fx:id="fileInput" text="Aucun fichier n'a ete selectionne" textFill="#94a3b8" style="-fx-font-size: 11;"/>
                                </children>
                            </HBox>
                        </VBox>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button maxWidth="Infinity" styleClass="primary-btn" text="Create Challenge" onAction="#onCreateChallenge">
                            <VBox.margin><Insets top="10.0"/></VBox.margin>
                        </Button>
                    </children>
                    <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/></padding>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>
