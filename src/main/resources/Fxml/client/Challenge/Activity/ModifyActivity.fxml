<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml/1"
      style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-border-color: #e2e8f0;"
        fx:controller="com.pidev.Controllers.client.Challenge.Activity.ModifyActivityController">
    <stylesheets>
        <URL value="@../../../../styles/challenge.css" />
    </stylesheets>

    <VBox fx:id="mainActivityContainer" spacing="10" />


    <VBox spacing="10" style="-fx-padding: 12; -fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e2e8f0;">
        <Label text="PROBLEMS &amp; SOLUTIONS" style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #6366f1;"/>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="200" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox fx:id="problemsModifContainer" spacing="10">
                <VBox spacing="8" style="-fx-padding: 10; -fx-background-color: #f8fafc; -fx-background-radius: 8;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <VBox spacing="2" minWidth="150" maxWidth="200">
                            <Label text="Problem Statement:" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: #0369a1;"/>
                            <Label fx:id="currentProbLabel" text="Original problem text..." wrapText="true" style="-fx-font-size: 11;"/>
                        </VBox>
                        <TextArea fx:id="probModifier" prefHeight="40" promptText="Edit Problem..." HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <VBox spacing="2" minWidth="150" maxWidth="200">
                            <Label text="Solution:" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: #0369a1;"/>
                            <Label fx:id="currentSolLabel" text="Original solution text..." wrapText="true" style="-fx-font-size: 11;"/>
                        </VBox>
                        <TextArea fx:id="solModifier" prefHeight="40" promptText="Edit Solution..." HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Update Row" style="-fx-background-color: #0369a1; -fx-text-fill: white; -fx-font-size: 10; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #eff6ff; -fx-padding: 8; -fx-background-radius: 8;">
        <Label text="📄" style="-fx-font-size: 16;"/>
        <VBox HBox.hgrow="ALWAYS">
            <Label text="CURRENT FILE" style="-fx-font-size: 8; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
            <Label fx:id="fileNameLabel" text="activity_doc.pdf" style="-fx-font-size: 11; -fx-text-fill: #1e40af;"/>
        </VBox>
        <Button text="Update File" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 10;"/>
    </HBox>
</VBox>